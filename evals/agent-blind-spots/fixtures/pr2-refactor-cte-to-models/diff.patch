diff --git a/models/int_customer_orders.sql b/models/int_customer_orders.sql
new file mode 100644
index 0000000..eec8bc8
--- /dev/null
+++ b/models/int_customer_orders.sql
@@ -0,0 +1,9 @@
+select
+    customer_id,
+
+    min(order_date) as first_order,
+    max(order_date) as most_recent_order,
+    count(order_id) as number_of_orders
+from {{ ref('stg_orders') }}
+
+group by customer_id
