{
  "name": "@datarecce/docs-mcp",
  "version": "0.1.0",
  "description": "Recce documentation service with MCP server and library API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "recce-docs-mcp": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "build:bundle": "bash scripts/build-bundle.sh",
    "prepare": "npm run build",
    "prepublishOnly": "npm test",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "release": "bash scripts/release.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DataRecce/recce-claude-plugin.git",
    "directory": "packages/recce-docs-mcp"
  },
  "homepage": "https://github.com/DataRecce/recce-claude-plugin/tree/main/packages/recce-docs-mcp#readme",
  "bugs": {
    "url": "https://github.com/DataRecce/recce-claude-plugin/issues"
  },
  "license": "Apache-2.0",
  "keywords": [
    "recce",
    "dbt",
    "mcp",
    "model-context-protocol",
    "documentation",
    "claude"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@types/turndown": "^5.0.5",
    "cheerio": "^1.0.0",
    "minisearch": "^7.1.1",
    "turndown": "^7.2.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "0.27.3",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
