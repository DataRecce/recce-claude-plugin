# Design documents (personal drafts, not for version control)
docs/plans/
docs/specs/
docs/superpowers/

# Root node_modules (esbuild installed here is not tracked; use packages/recce-docs-mcp/node_modules)
node_modules/

# GSD planning (local-only)
.planning/

# Private journal (local-only)
.private-journal/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
ENV/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Temporary files
tmp/
temp/
*.tmp
.worktrees/

# DRC-3402 eval fixtures — regenerable artifacts (see evals/agent-blind-spots/fixtures/README.md)
evals/agent-blind-spots/.tmp/
evals/agent-blind-spots/fixtures/*/artifacts/

# Coverage / editor logs
.coverage
.nvimlog

# Claude Code local state (eval runs, transcripts, etc.).
# Note: `.claude-plugin/` is a different path and remains tracked.
.claude/

# Local recce config (project-specific, not for the marketplace repo)
recce.yml

# Bundled MCP runtime caches (rebuilt locally when the server runs)
plugins/*/servers/recce-docs-mcp/cache/

# Beads/Dolt server runtime state (machine-local PIDs, locks, DB files)
.beads/dolt/
.beads/dolt-server.*
