{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/sync-mcp-port.sh",
            "timeout": 10,
            "statusMessage": "Syncing MCP port configuration..."
          }
        ]
      }
    ]
  }
}
